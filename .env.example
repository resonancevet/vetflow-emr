# -----------------------------------------------------------------------------
# Copy this file to the REPO ROOT as `.env` (same folder as package.json).
# Do not put it only under apps/web — every app loads the root file via @openpims/config/load-env.
# Optional overrides: `.env.local` at the repo root (gitignored).
# -----------------------------------------------------------------------------

# Database (local Docker defaults — change credentials for production)
DATABASE_URL="postgresql://openpims:openpims@localhost:5432/openpims"

# NextAuth — REQUIRED: generate a real secret before real data
# Run: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-secret-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Demo shortcuts on the sign-in page (dev only — set false for real data)
NEXT_PUBLIC_DEMO_MODE="false"

# Allow new practice registration at /register (set false after your practice is created)
ALLOW_REGISTRATION="true"

# Demo seed only — never set true against a database with real data
# SEED_DEMO="true"

# Marketing site (production). Local www runs on port 4000 via `pnpm dev`.
# NEXT_PUBLIC_WWW_URL="http://localhost:4000"

# S3-compatible storage (MinIO for local dev — use real S3/R2 credentials in production)
S3_ENDPOINT="http://localhost:9000"
S3_ACCESS_KEY="openpims"
S3_SECRET_KEY="openpims123"
S3_BUCKET="openpims"
S3_REGION="us-east-1"

# Resend (email)
RESEND_API_KEY=

# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cron job authentication
CRON_SECRET=

# Lab Integrations
IDEXX_API_KEY=
ANTECH_API_KEY=
ZOETIS_API_KEY=
