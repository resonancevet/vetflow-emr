# -----------------------------------------------------------------------------
# Production environment template (hosted deploy — Vercel, Railway, etc.)
#
# Do NOT use this file for local dev. Keep MinIO in `.env` on your laptop.
#
# Setup:
#   1. Copy to `.env.production` for local `next build` / `next start` testing, OR
#   2. Paste each variable into your host's dashboard (recommended for Vercel).
#
# `.env.production` is gitignored — never commit real secrets.
# -----------------------------------------------------------------------------

# Database (Neon — use the pooled connection string for the app)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="https://app.yourdomain.com"

NEXT_PUBLIC_DEMO_MODE="false"
ALLOW_REGISTRATION="false"

# Cloudflare R2 (S3-compatible)
# Dashboard → R2 → your bucket → Settings → S3 API
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
S3_ENDPOINT="https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com"
S3_ACCESS_KEY="YOUR_R2_ACCESS_KEY_ID"
S3_SECRET_KEY="YOUR_R2_SECRET_ACCESS_KEY"
S3_BUCKET="vetflow-emr"
S3_REGION="auto"

# Cron (Vercel sends this header on scheduled jobs)
CRON_SECRET="generate-with-openssl-rand-base64-32"

# Optional integrations
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
IDEXX_API_KEY=
ANTECH_API_KEY=
ZOETIS_API_KEY=
